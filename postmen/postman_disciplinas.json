{
  "info": {
    "_postman_id": "019ad331-fcfb-4d10-a7a1-820dfb9accce",
    "name": "Sistema Escolar - Disciplinas",
    "description": "Colecao para testar o CRUD do modulo de disciplinas.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "identificador", "value": "admin" },
    { "key": "senha", "value": "123456" },
    { "key": "accessToken", "value": "" },
    { "key": "secretariaId", "value": "" },
    { "key": "disciplinaId", "value": "" }
  ],
  "item": [
    {
      "name": "Entrar",
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const resposta = pm.response.json();", "if (resposta.accessToken) pm.collectionVariables.set('accessToken', resposta.accessToken);"] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"identificador\": \"{{identificador}}\",\n  \"senha\": \"{{senha}}\"\n}" },
        "url": "{{baseUrl}}/autenticacao/entrar"
      }
    },
    {
      "name": "Criar Secretaria Para Teste",
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const resposta = pm.response.json();", "if (resposta.id) pm.collectionVariables.set('secretariaId', resposta.id);"] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Secretaria Para Disciplina\",\n  \"municipio\": \"Sao Paulo\",\n  \"uf\": \"SP\",\n  \"cnpj\": \"00000000000104\",\n  \"telefone\": \"1130000004\",\n  \"email\": \"secretaria.disciplina@sistema.local\",\n  \"ativa\": true\n}" },
        "url": "{{baseUrl}}/secretarias"
      }
    },
    {
      "name": "Criar Disciplina",
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const resposta = pm.response.json();", "if (resposta.id) pm.collectionVariables.set('disciplinaId', resposta.id);"] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "body": { "mode": "raw", "raw": "{\n  \"secretariaId\": \"{{secretariaId}}\",\n  \"nome\": \"Matematica\",\n  \"codigo\": \"MAT\",\n  \"ativa\": true\n}" },
        "url": "{{baseUrl}}/disciplinas"
      }
    },
    {
      "name": "Listar Disciplinas",
      "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/disciplinas" }
    },
    {
      "name": "Buscar Disciplina Por Id",
      "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/disciplinas/{{disciplinaId}}" }
    },
    {
      "name": "Atualizar Disciplina",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Matematica Atualizada\",\n  \"codigo\": \"MAT-AT\"\n}" },
        "url": "{{baseUrl}}/disciplinas/{{disciplinaId}}"
      }
    },
    {
      "name": "Inativar Disciplina",
      "request": { "method": "PATCH", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/disciplinas/{{disciplinaId}}/inativar" }
    },
    {
      "name": "Remover Disciplina",
      "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/disciplinas/{{disciplinaId}}" }
    }
  ]
}
