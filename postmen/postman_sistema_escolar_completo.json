    {
      "name": "Selecionar Perfil Professor",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const resposta = pm.response.json();",
              "const perfis = Array.isArray(resposta) ? resposta : [];",
              "const perfil = perfis.find((item) => item.codigo === 'PROFESSOR');",
              "if (perfil && perfil.id) pm.collectionVariables.set('perfilId', perfil.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
