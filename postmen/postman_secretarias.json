{
  "info": {
    "_postman_id": "52e29139-2694-467e-a06e-e1bfb5e859c5",
    "name": "Sistema Escolar - Secretarias",
    "description": "Colecao para testar o CRUD do modulo de secretarias.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "identificador",
      "value": "admin"
    },
    {
      "key": "senha",
      "value": "123456"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "secretariaId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Autenticacao",
      "item": [
        {
          "name": "Entrar",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', resposta.accessToken);",
                  "}",
                  "if (resposta.refreshToken) {",
                  "  pm.collectionVariables.set('refreshToken', resposta.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identificador\": \"{{identificador}}\",\n  \"senha\": \"{{senha}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/autenticacao/entrar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "autenticacao",
                "entrar"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Secretarias",
      "item": [
        {
          "name": "Criar Secretaria",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.id) {",
                  "  pm.collectionVariables.set('secretariaId', resposta.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Secretaria Municipal de Educacao\",\n  \"municipio\": \"Sao Paulo\",\n  \"uf\": \"SP\",\n  \"cnpj\": \"00000000000100\",\n  \"telefone\": \"1130000000\",\n  \"email\": \"educacao@sistema.local\",\n  \"ativa\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/secretarias",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "secretarias"
              ]
            }
          }
        },
        {
          "name": "Listar Secretarias",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/secretarias",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "secretarias"
              ]
            }
          }
        },
        {
          "name": "Buscar Secretaria Por Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/secretarias/{{secretariaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "secretarias",
                "{{secretariaId}}"
              ]
            }
          }
        },
        {
          "name": "Atualizar Secretaria",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Secretaria Municipal de Educacao Atualizada\",\n  \"telefone\": \"1130001111\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/secretarias/{{secretariaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "secretarias",
                "{{secretariaId}}"
              ]
            }
          }
        },
        {
          "name": "Inativar Secretaria",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/secretarias/{{secretariaId}}/inativar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "secretarias",
                "{{secretariaId}}",
                "inativar"
              ]
            }
          }
        },
        {
          "name": "Remover Secretaria",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/secretarias/{{secretariaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "secretarias",
                "{{secretariaId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
