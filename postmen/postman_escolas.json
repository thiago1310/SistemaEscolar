  ],
  "item": [
    {
      "name": "Autenticacao",
      "item": [
        {
          "name": "Entrar",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', resposta.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identificador\": \"{{identificador}}\",\n  \"senha\": \"{{senha}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/autenticacao/entrar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "autenticacao",
                "entrar"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Preparacao",
      "item": [
        {
          "name": "Criar Secretaria Para Teste",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.id) {",
                  "  pm.collectionVariables.set('secretariaId', resposta.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Secretaria Para Escola\",\n  \"municipio\": \"Sao Paulo\",\n  \"uf\": \"SP\",\n  \"cnpj\": \"00000000000101\",\n  \"telefone\": \"1130000001\",\n  \"email\": \"secretaria.escola@sistema.local\",\n  \"ativa\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/secretarias",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "secretarias"
              ]
            }
          }
        }
