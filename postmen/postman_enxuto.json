  "item": [
    {
      "name": "Autenticacao",
      "item": [
        {
          "name": "Entrar",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.accessToken) pm.collectionVariables.set('accessToken', resposta.accessToken);",
                  "if (resposta.refreshToken) pm.collectionVariables.set('refreshToken', resposta.refreshToken);",
                  "if (resposta.usuario && resposta.usuario.id) pm.collectionVariables.set('usuarioId', resposta.usuario.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identificador\": \"{{identificador}}\",\n  \"senha\": \"{{senha}}\"\n}"
            },
            "url": "{{baseUrl}}/autenticacao/entrar"
          }
        },
        {
          "name": "Perfil",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.usuario && resposta.usuario.id) pm.collectionVariables.set('usuarioId', resposta.usuario.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/autenticacao/perfil"
          }
        }
      ]
    },
    {
      "name": "Perfis",
      "item": [
        {
          "name": "Listar Perfis",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resposta = pm.response.json();",
                  "const perfis = Array.isArray(resposta) ? resposta : [];",
                  "const perfil = perfis.find((item) => item.codigo === 'PROFESSOR') || perfis.find((item) => item.codigo === 'ADMIN_GERAL') || perfis[0];",
                  "if (perfil && perfil.id) pm.collectionVariables.set('perfilId', perfil.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/perfis"
          }
        }
      ]
    },
