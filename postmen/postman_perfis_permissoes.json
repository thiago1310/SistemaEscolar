{
  "info": {
    "_postman_id": "8a25d70e-b72d-4730-b5e0-8d54877b40f4",
    "name": "Sistema Escolar - Perfis e Permissoes",
    "description": "Colecao para testar perfis, permissoes e vinculos entre eles.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "identificador", "value": "admin" },
    { "key": "senha", "value": "123456" },
    { "key": "accessToken", "value": "" },
    { "key": "perfilId", "value": "" },
    { "key": "permissaoId", "value": "" }
  ],
  "item": [
    {
      "name": "Entrar",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const resposta = pm.response.json();",
              "if (resposta.accessToken) pm.collectionVariables.set('accessToken', resposta.accessToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identificador\": \"{{identificador}}\",\n  \"senha\": \"{{senha}}\"\n}"
        },
        "url": "{{baseUrl}}/autenticacao/entrar"
      }
    },
    {
      "name": "Criar Perfil",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const resposta = pm.response.json();",
              "if (resposta.id) pm.collectionVariables.set('perfilId', resposta.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Perfil Teste\",\n  \"codigo\": \"PERFIL_TESTE\",\n  \"descricao\": \"Perfil criado pelo Postman.\",\n  \"nivel\": 10,\n  \"sistema\": false,\n  \"ativo\": true\n}"
        },
        "url": "{{baseUrl}}/perfis"
      }
    },
    {
      "name": "Listar Perfis",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/perfis"
      }
    },
    {
      "name": "Buscar Perfil Por Id",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/perfis/{{perfilId}}"
      }
    },
    {
      "name": "Atualizar Perfil",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"descricao\": \"Perfil atualizado pelo Postman.\",\n  \"nivel\": 20\n}"
        },
        "url": "{{baseUrl}}/perfis/{{perfilId}}"
      }
    },
    {
      "name": "Criar Permissao",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const resposta = pm.response.json();",
              "if (resposta.id) pm.collectionVariables.set('permissaoId', resposta.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"modulo\": \"teste\",\n  \"acao\": \"visualizar\",\n  \"codigo\": \"teste.visualizar\",\n  \"descricao\": \"Permissao criada pelo Postman.\"\n}"
        },
        "url": "{{baseUrl}}/permissoes"
      }
    },
    {
      "name": "Listar Permissoes",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/permissoes"
      }
    },
    {
      "name": "Vincular Permissao Ao Perfil",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"permissaoId\": \"{{permissaoId}}\"\n}"
        },
        "url": "{{baseUrl}}/perfis/{{perfilId}}/permissoes"
      }
    },
    {
      "name": "Listar Permissoes Do Perfil",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/perfis/{{perfilId}}/permissoes"
      }
    },
    {
      "name": "Desvincular Permissao Do Perfil",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/perfis/{{perfilId}}/permissoes/{{permissaoId}}"
      }
    }
  ]
}
