{
  "info": {
    "_postman_id": "c490ef33-8d21-43d8-9b40-75c8d0477516",
    "name": "Sistema Escolar - Autenticacao",
    "description": "Colecao para testar login, token de acesso, refresh token, perfil e logout.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "identificador",
      "value": "admin"
    },
    {
      "key": "senha",
      "value": "123456"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Autenticacao",
      "item": [
        {
          "name": "Entrar",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', resposta.accessToken);",
                  "}",
                  "if (resposta.refreshToken) {",
                  "  pm.collectionVariables.set('refreshToken', resposta.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identificador\": \"{{identificador}}\",\n  \"senha\": \"{{senha}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/autenticacao/entrar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "autenticacao",
                "entrar"
              ]
            }
          }
        },
        {
          "name": "Perfil",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/autenticacao/perfil",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "autenticacao",
                "perfil"
              ]
            }
          }
        },
        {
          "name": "Renovar Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', resposta.accessToken);",
                  "}",
                  "if (resposta.refreshToken) {",
                  "  pm.collectionVariables.set('refreshToken', resposta.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/autenticacao/renovar-token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "autenticacao",
                "renovar-token"
              ]
            }
          }
        },
        {
          "name": "Sair",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/autenticacao/sair",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "autenticacao",
                "sair"
              ]
            }
          }
        }
      ]
    }
  ]
}
