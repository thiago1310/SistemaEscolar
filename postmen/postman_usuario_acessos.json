{
  "info": {
    "_postman_id": "21bb29ff-125f-4502-a00c-67c65ad30547",
    "name": "Sistema Escolar - Usuario Acessos",
    "description": "Colecao para testar acessos do usuario usando perfis fixos por nivel e escopo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "identificador",
      "value": "admin"
    },
    {
      "key": "senha",
      "value": "123456"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "usuarioId",
      "value": ""
    },
    {
      "key": "perfilId",
      "value": ""
    },
    {
      "key": "secretariaId",
      "value": ""
    },
    {
      "key": "usuarioAcessoId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Entrar",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const resposta = pm.response.json();",
              "if (resposta.accessToken) pm.collectionVariables.set('accessToken', resposta.accessToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identificador\": \"{{identificador}}\",\n  \"senha\": \"{{senha}}\"\n}"
        },
        "url": "{{baseUrl}}/autenticacao/entrar"
      }
    },
    {
      "name": "Criar Usuario",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const resposta = pm.response.json();",
              "if (resposta.id) pm.collectionVariables.set('usuarioId', resposta.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Usuario Teste {{$timestamp}}\",\n  \"email\": \"usuario{{$timestamp}}@sistema.local\",\n  \"username\": \"usuario{{$timestamp}}\",\n  \"senha\": \"123456\",\n  \"ativo\": true\n}"
        },
        "url": "{{baseUrl}}/usuarios"
      }
    },
    {
      "name": "Selecionar Perfil Professor",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const resposta = pm.response.json();",
              "const perfis = Array.isArray(resposta) ? resposta : [];",
              "const perfil = perfis.find((item) => item.codigo === 'PROFESSOR');",
              "if (perfil && perfil.id) pm.collectionVariables.set('perfilId', perfil.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/perfis"
      }
    },
    {
      "name": "Criar Secretaria Para Teste",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const resposta = pm.response.json();",
              "if (resposta.id) pm.collectionVariables.set('secretariaId', resposta.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Secretaria Para Acesso\",\n  \"municipio\": \"Sao Paulo\",\n  \"uf\": \"SP\",\n  \"cnpj\": \"00000000000105\",\n  \"telefone\": \"1130000005\",\n  \"email\": \"secretaria.acesso@sistema.local\",\n  \"ativa\": true\n}"
        },
        "url": "{{baseUrl}}/secretarias"
      }
    },
    {
      "name": "Criar Usuario Acesso",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const resposta = pm.response.json();",
              "if (resposta.id) pm.collectionVariables.set('usuarioAcessoId', resposta.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usuarioId\": \"{{usuarioId}}\",\n  \"perfilId\": \"{{perfilId}}\",\n  \"secretariaId\": \"{{secretariaId}}\",\n  \"ativo\": true\n}"
        },
        "url": "{{baseUrl}}/usuario-acessos"
      }
    },
    {
      "name": "Listar Usuario Acessos",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/usuario-acessos"
      }
    },
    {
      "name": "Buscar Usuario Acesso Por Id",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/usuario-acessos/{{usuarioAcessoId}}"
      }
    },
    {
      "name": "Atualizar Usuario Acesso",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ativo\": true\n}"
        },
        "url": "{{baseUrl}}/usuario-acessos/{{usuarioAcessoId}}"
      }
    },
    {
      "name": "Inativar Usuario Acesso",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/usuario-acessos/{{usuarioAcessoId}}/inativar"
      }
    },
    {
      "name": "Remover Usuario Acesso",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/usuario-acessos/{{usuarioAcessoId}}"
      }
    }
  ]
}
