                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Secretaria Para Ano Letivo\",\n  \"municipio\": \"Sao Paulo\",\n  \"uf\": \"SP\",\n  \"cnpj\": \"00000000000103\",\n  \"telefone\": \"1130000003\",\n  \"email\": \"secretaria.ano@sistema.local\",\n  \"ativa\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/secretarias",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "secretarias"
              ]
            }
          }
