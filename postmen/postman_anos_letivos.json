            {
              "listen": "test",
              "script": {
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.id) {",
                  "  pm.collectionVariables.set('secretariaId', resposta.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
