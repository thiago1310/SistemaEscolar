{
  "info": {
    "_postman_id": "91504393-c928-9f93-3447-1c6a0acb0e5a",
    "name": "Sistema Escolar - Autenticacao",
    "description": "Collection do modulo autenticacao.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "identificador",
      "value": ""
    },
    {
      "key": "senha",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "usuarioId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Entrar",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const resposta = pm.response.json();",
              "if (resposta.accessToken) pm.collectionVariables.set('accessToken', resposta.accessToken);",
              "if (resposta.refreshToken) pm.collectionVariables.set('refreshToken', resposta.refreshToken);",
              "if (resposta.usuario && resposta.usuario.id) pm.collectionVariables.set('usuarioId', resposta.usuario.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{url_base}}/autenticacao/entrar",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identificador\": \"{{identificador}}\",\n  \"senha\": \"{{senha}}\"\n}"
        }
      }
    },
    {
      "name": "Renovar Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const resposta = pm.response.json();",
              "if (resposta.accessToken) pm.collectionVariables.set('accessToken', resposta.accessToken);",
              "if (resposta.refreshToken) pm.collectionVariables.set('refreshToken', resposta.refreshToken);",
              "if (resposta.usuario && resposta.usuario.id) pm.collectionVariables.set('usuarioId', resposta.usuario.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{url_base}}/autenticacao/renovar-token",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        }
      }
    },
    {
      "name": "Perfil Autenticado",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/autenticacao/perfil"
      }
    },
    {
      "name": "Sair",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{url_base}}/autenticacao/sair",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        }
      }
    }
  ]
}
