{
  "info": {
    "_postman_id": "f9b4735a-eb2f-42f4-f87e-67dad469b544",
    "name": "Sistema Escolar - Secretarias",
    "description": "Collection do modulo secretarias com exemplos essenciais e completos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "secretariaId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "POST Criar Secretaria",
      "item": [
        {
          "name": "Criar Secretaria - Dados essenciais",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.id) pm.collectionVariables.set('secretariaId', resposta.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/secretarias",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Secretaria Municipal {{$timestamp}}\",\n  \"municipio\": \"Sao Paulo\",\n  \"uf\": \"SP\"\n}"
            }
          }
        },
        {
          "name": "Criar Secretaria - Dados completos",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.id) pm.collectionVariables.set('secretariaId', resposta.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/secretarias",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Secretaria Completa {{$timestamp}}\",\n  \"municipio\": \"Sao Paulo\",\n  \"uf\": \"SP\",\n  \"cnpj\": \"00000000000101\",\n  \"telefone\": \"1130000001\",\n  \"email\": \"secretaria{{$timestamp}}@sistema.local\",\n  \"ativa\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Listar Secretarias",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/secretarias"
      }
    },
    {
      "name": "Buscar Secretaria Por Id",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/secretarias/{{secretariaId}}"
      }
    },
    {
      "name": "PATCH Atualizar Secretaria",
      "item": [
        {
          "name": "Atualizar Secretaria - Dados essenciais",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/secretarias/{{secretariaId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Secretaria Atualizada\"\n}"
            }
          }
        },
        {
          "name": "Atualizar Secretaria - Dados completos",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/secretarias/{{secretariaId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Secretaria Completa Atualizada\",\n  \"municipio\": \"Sao Paulo\",\n  \"uf\": \"SP\",\n  \"cnpj\": \"00000000000109\",\n  \"telefone\": \"1130000009\",\n  \"email\": \"secretaria.atualizada@sistema.local\",\n  \"ativa\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Inativar Secretaria",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/secretarias/{{secretariaId}}/inativar"
      }
    },
    {
      "name": "Remover Secretaria",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/secretarias/{{secretariaId}}"
      }
    }
  ]
}
