{
  "info": {
    "_postman_id": "9a0e9d1d-0a15-4113-b5cb-83f81d6c91d6",
    "name": "Sistema Escolar - Professores",
    "description": "Collection do modulo professores. O cadastro cria ou atualiza usuario, acesso PROFESSOR e professor em uma unica chamada. Se o vinculo ja existir, ele e reativado/atualizado. A listagem sincroniza usuarios com acesso PROFESSOR ativo para recuperar cadastros legados sem registro em professores.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "professorId",
      "value": ""
    },
    {
      "key": "secretariaId",
      "value": ""
    },
    {
      "key": "escolaId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "POST Criar Professor",
      "item": [
        {
          "name": "Criar Professor - Dados essenciais",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.id) pm.collectionVariables.set('professorId', resposta.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/professores",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Professor Teste {{$timestamp}}\",\n  \"email\": \"professor{{$timestamp}}@sistema.local\",\n  \"username\": \"professor{{$timestamp}}\",\n  \"enviarEmailBoasVindas\": false\n}"
            }
          }
        },
        {
          "name": "Criar Professor - Dados completos",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.id) pm.collectionVariables.set('professorId', resposta.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/professores",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Professor Completo {{$timestamp}}\",\n  \"cpf\": \"12345678901\",\n  \"email\": \"professor.completo{{$timestamp}}@sistema.local\",\n  \"telefone\": \"11999999999\",\n  \"dataNascimento\": \"1990-10-13\",\n  \"cargo\": \"Professor\",\n  \"observacoes\": \"Conta de professor criada pelo modulo professores.\",\n  \"username\": \"professor.completo{{$timestamp}}\",\n  \"matricula\": \"PROF{{$timestamp}}\",\n  \"dataAdmissao\": \"2024-02-01\",\n  \"formacao\": \"Licenciatura em Letras\",\n  \"secretariaId\": \"{{secretariaId}}\",\n  \"escolaIds\": [\"{{escolaId}}\"],\n  \"ativo\": true,\n  \"enviarEmailBoasVindas\": false\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Listar Professores",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/professores"
      }
    },
    {
      "name": "Buscar Professor Por Id",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/professores/{{professorId}}"
      }
    },
    {
      "name": "PATCH Atualizar Professor",
      "item": [
        {
          "name": "Atualizar Professor - Dados essenciais",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/professores/{{professorId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"formacao\": \"Licenciatura atualizada\"\n}"
            }
          }
        },
        {
          "name": "Atualizar Professor - Dados completos",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/professores/{{professorId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Professor Completo Atualizado\",\n  \"cpf\": \"12345678901\",\n  \"email\": \"professor.atualizado@sistema.local\",\n  \"telefone\": \"11888888888\",\n  \"dataNascimento\": \"1991-10-13\",\n  \"cargo\": \"Professor Regente\",\n  \"observacoes\": \"Observacao interna atualizada.\",\n  \"username\": \"professor.atualizado\",\n  \"matricula\": \"PROF-ATUALIZADA\",\n  \"dataAdmissao\": \"2024-03-01\",\n  \"formacao\": \"Licenciatura em Matematica\",\n  \"ativo\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Inativar Professor",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/professores/{{professorId}}/inativar"
      }
    },
    {
      "name": "Remover Professor",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/professores/{{professorId}}"
      }
    }
  ]
}
