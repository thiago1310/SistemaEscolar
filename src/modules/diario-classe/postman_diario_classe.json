{
  "info": {
    "_postman_id": "7e02fd2d-9f78-4d11-a93b-diario-classe",
    "name": "Sistema Escolar - Diario de Classe",
    "description": "Collection do modulo diario-classe. Leitura respeita escopo no backend; escrita exige professor com vinculo docente ativo na turma.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "accessToken", "value": "" },
    { "key": "turmaId", "value": "" },
    { "key": "disciplinaId", "value": "" },
    { "key": "alunoId", "value": "" },
    { "key": "avaliacaoId", "value": "" },
    { "key": "aulaId", "value": "" },
    { "key": "observacaoId", "value": "" }
  ],
  "item": [
    {
      "name": "Listar turmas do diario",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{url_base}}/diario-classe/turmas"
      }
    },
    {
      "name": "Resumo da turma",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{url_base}}/diario-classe/turmas/{{turmaId}}/resumo"
      }
    },
    {
      "name": "Salvar frequencia diaria",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{url_base}}/diario-classe/turmas/{{turmaId}}/frequencias",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"data\": \"2026-06-30\",\n  \"disciplinaId\": \"{{disciplinaId}}\",\n  \"registros\": [\n    {\n      \"alunoId\": \"{{alunoId}}\",\n      \"situacao\": \"PRESENTE\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Criar aula/conteudo",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{url_base}}/diario-classe/turmas/{{turmaId}}/aulas",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"disciplinaId\": \"{{disciplinaId}}\",\n  \"data\": \"2026-06-30\",\n  \"horaInicio\": \"08:00\",\n  \"horaFim\": \"08:50\",\n  \"titulo\": \"Numeros decimais\",\n  \"conteudo\": \"Adicao e subtracao com numeros decimais.\",\n  \"periodo\": \"2 Bimestre\"\n}"
        }
      }
    },
    {
      "name": "Criar avaliacao",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{url_base}}/diario-classe/turmas/{{turmaId}}/avaliacoes",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"disciplinaId\": \"{{disciplinaId}}\",\n  \"nome\": \"AV1 - Prova\",\n  \"periodo\": \"2 Bimestre\",\n  \"peso\": 40,\n  \"data\": \"2026-06-30\"\n}"
        }
      }
    },
    {
      "name": "Salvar notas",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{url_base}}/diario-classe/avaliacoes/{{avaliacaoId}}/notas",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"notas\": [\n    {\n      \"alunoId\": \"{{alunoId}}\",\n      \"valor\": 8.5,\n      \"observacao\": \"Bom desempenho.\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Criar observacao",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{url_base}}/diario-classe/turmas/{{turmaId}}/observacoes",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"alunoId\": \"{{alunoId}}\",\n  \"data\": \"2026-06-30\",\n  \"tipo\": \"ACOMPANHAMENTO\",\n  \"resumo\": \"Dificuldade em fracoes\",\n  \"descricao\": \"Aluno precisa retomar operacoes com fracoes.\",\n  \"encaminhamentos\": \"Atividade dirigida na proxima aula.\"\n}"
        }
      }
    }
  ]
}
