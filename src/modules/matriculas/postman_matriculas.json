              }
            ],
            "url": "{{url_base}}/matriculas?tenantSlug={{tenantSlug}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"{{alunoId}}\",\n  \"targetSchoolId\": \"{{escolaId}}\",\n  \"targetClassId\": \"{{turmaId}}\",\n  \"type\": \"Rematrícula\",\n  \"sourceYear\": 2025,\n  \"targetYear\": 2026,\n  \"mode\": \"automatico\"\n}"
            }
          }
        }
      ]
    },
    {
