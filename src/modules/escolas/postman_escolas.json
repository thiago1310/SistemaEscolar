  "item": [
    {
      "name": "POST Criar Escola",
      "item": [
        {
          "name": "Criar Escola - Dados essenciais",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.id) pm.collectionVariables.set('escolaId', resposta.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/escolas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"secretariaId\": \"{{secretariaId}}\",\n  \"nome\": \"Escola Municipal {{$timestamp}}\"\n}"
            }
          }
        },
        {
          "name": "Criar Escola - Dados completos",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
