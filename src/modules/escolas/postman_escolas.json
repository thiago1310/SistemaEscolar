            "url": "{{url_base}}/escolas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"secretariaId\": \"{{secretariaId}}\",\n  \"nome\": \"Escola Completa {{$timestamp}}\",\n  \"codigoInep\": \"INEP{{$timestamp}}\",\n  \"tipoEscola\": \"Urbana\",\n  \"modalidadesEnsino\": [\n    \"Creche\",\n    \"Pré-escola\",\n    \"Ensino Fundamental - Anos Iniciais\",\n    \"Ensino Fundamental - Anos Finais\"\n  ],\n  \"cnpj\": \"00000000000102\",\n  \"telefone\": \"1130000002\",\n  \"email\": \"escola{{$timestamp}}@sistema.local\",\n  \"cep\": \"01001000\",\n  \"endereco\": \"Praca da Se\",\n  \"numero\": \"100\",\n  \"complemento\": \"Predio Principal\",\n  \"bairro\": \"Centro\",\n  \"municipio\": \"Sao Paulo\",\n  \"uf\": \"SP\",\n  \"ativa\": true,\n  \"observacoes\": \"Informacoes diversas sobre a unidade escolar.\"\n}"
            }
