{
  "info": {
    "_postman_id": "e0d9e34d-7ac9-4771-b9a8-61fe4f1e8a70",
    "name": "Sistema Escolar - Alunos",
    "description": "Collection do modulo alunos. O campo escolaId e opcional para usuario global; para usuario com uma unica escola no escopo, a API assume essa escola quando omitido. Para demais escopos, informe escolaId.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "alunoId",
      "value": ""
    },
    {
      "key": "escolaId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "POST Criar Aluno",
      "item": [
        {
          "name": "Criar Aluno - Tela novo aluno",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.id) pm.collectionVariables.set('alunoId', resposta.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/alunos",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeCompleto\": \"Ana Clara Martins\",\n  \"cpfOuCertidao\": \"12345678900\",\n  \"dataNascimento\": \"2016-05-10\",\n  \"ativo\": true,\n  \"responsavelNome\": \"Camila Martins\",\n  \"responsavelTelefone\": \"49999112200\"\n}"
            }
          }
        },
        {
          "name": "Criar Aluno - Com escola",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.id) pm.collectionVariables.set('alunoId', resposta.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/alunos",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"escolaId\": \"{{escolaId}}\",\n  \"nomeCompleto\": \"Ana Clara Martins\",\n  \"cpfOuCertidao\": \"12345678900\",\n  \"dataNascimento\": \"2016-05-10\",\n  \"ativo\": true,\n  \"responsavelNome\": \"Camila Martins\",\n  \"responsavelTelefone\": \"49999112200\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Listar Alunos",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/alunos"
      }
    },
    {
      "name": "Buscar Aluno Por Id",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/alunos/{{alunoId}}"
      }
    },
    {
      "name": "PATCH Atualizar Aluno",
      "item": [
        {
          "name": "Atualizar Aluno - Tela novo aluno",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/alunos/{{alunoId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeCompleto\": \"Ana Clara Martins Silva\",\n  \"cpfOuCertidao\": \"12345678900\",\n  \"dataNascimento\": \"2016-05-10\",\n  \"ativo\": true,\n  \"responsavelNome\": \"Camila Martins\",\n  \"responsavelTelefone\": \"49999112200\"\n}"
            }
          }
        },
        {
          "name": "Atualizar Aluno - Vincular escola",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/alunos/{{alunoId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"escolaId\": \"{{escolaId}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Inativar Aluno",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/alunos/{{alunoId}}/inativar"
      }
    },
    {
      "name": "Remover Aluno",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/alunos/{{alunoId}}"
      }
    }
  ]
}
