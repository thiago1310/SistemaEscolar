{
  "info": {
    "_postman_id": "53a4da7c-acc7-e16f-84e6-7f71971fad40",
    "name": "Sistema Escolar - Perfis e Permissoes",
    "description": "Collection do modulo perfis-permissoes com exemplos essenciais e completos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "perfilId",
      "value": ""
    },
    {
      "key": "permissaoId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "POST Criar Perfil",
      "item": [
        {
          "name": "Criar Perfil - Dados essenciais",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.id) pm.collectionVariables.set('perfilId', resposta.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/perfis",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Perfil Teste {{$timestamp}}\",\n  \"codigo\": \"PERFIL_TESTE_{{$timestamp}}\"\n}"
            }
          }
        },
        {
          "name": "Criar Perfil - Dados completos",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.id) pm.collectionVariables.set('perfilId', resposta.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/perfis",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Perfil Completo {{$timestamp}}\",\n  \"codigo\": \"PERFIL_COMPLETO_{{$timestamp}}\",\n  \"descricao\": \"Perfil completo para testes.\",\n  \"nivel\": 10,\n  \"sistema\": false,\n  \"ativo\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Listar Perfis",
      "request": {
        "description": "Retorna apenas perfis com nivel menor ou igual ao maior nivel do usuario autenticado.",
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/perfis"
      }
    },
    {
      "name": "Buscar Perfil Por Id",
      "request": {
        "description": "Retorna o perfil apenas se o nivel for menor ou igual ao maior nivel do usuario autenticado.",
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/perfis/{{perfilId}}"
      }
    },
