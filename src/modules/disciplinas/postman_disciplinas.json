{
  "info": {
    "_postman_id": "0d0d23fe-69a7-9fde-c87a-89f2f48e629f",
    "name": "Sistema Escolar - Disciplinas",
    "description": "Collection do modulo disciplinas com exemplos essenciais e completos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "secretariaId",
      "value": ""
    },
    {
      "key": "disciplinaId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "POST Criar Disciplina",
      "item": [
        {
          "name": "Criar Disciplina - Dados essenciais",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.id) pm.collectionVariables.set('disciplinaId', resposta.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/disciplinas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"secretariaId\": \"{{secretariaId}}\",\n  \"nome\": \"Matematica {{$timestamp}}\"\n}"
            }
          }
        },
        {
          "name": "Criar Disciplina - Dados completos",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resposta = pm.response.json();",
                  "if (resposta.id) pm.collectionVariables.set('disciplinaId', resposta.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/disciplinas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"secretariaId\": \"{{secretariaId}}\",\n  \"nome\": \"Matematica Completa {{$timestamp}}\",\n  \"codigo\": \"MAT{{$timestamp}}\",\n  \"ativa\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Listar Disciplinas",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/disciplinas"
      }
    },
    {
      "name": "Buscar Disciplina Por Id",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/disciplinas/{{disciplinaId}}"
      }
    },
    {
      "name": "PATCH Atualizar Disciplina",
      "item": [
        {
          "name": "Atualizar Disciplina - Dados essenciais",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/disciplinas/{{disciplinaId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Disciplina Atualizada\"\n}"
            }
          }
        },
        {
          "name": "Atualizar Disciplina - Dados completos",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{url_base}}/disciplinas/{{disciplinaId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"secretariaId\": \"{{secretariaId}}\",\n  \"nome\": \"Disciplina Completa Atualizada\",\n  \"codigo\": \"DISC_ATUALIZADA\",\n  \"ativa\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Inativar Disciplina",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/disciplinas/{{disciplinaId}}/inativar"
      }
    },
    {
      "name": "Remover Disciplina",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{url_base}}/disciplinas/{{disciplinaId}}"
      }
    }
  ]
}
